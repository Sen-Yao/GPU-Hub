<?xml version="1.0"?>
<Container version="2">
  <Name>GPUHub</Name>
  <Repository>local/gpuhub:latest</Repository>
  <Registry/>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project>https://github.com/Sen-Yao/gpuhub</Project>
  <Overview>GPU 任务调度平台 - 总控端。FastAPI + Redis + MySQL + 前端仪表盘。</Overview>
  <Category>Productivity:</Category>
  <WebUI>http://[IP]:[PORT:8001]</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/Sen-Yao/gpuhub/main/docs/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled></DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Description>GPUHub 是一个轻量级的 GPU 任务调度平台，实现多节点统一管理、任务队列、请求跟踪、前端仪表盘。</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>8001</HostPort>
        <ContainerPort>8001</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/gpuhub/frontend</HostDir>
      <ContainerDir>/app/frontend</ContainerDir>
      <Mode>ro</Mode>
    </Volume>
  </Data>
  <Environment>
    <Var>
      <Value>192.168.1.6</Value>
      <Name>REDIS_HOST</Name>
      <Mode/>
    </Var>
    <Var>
      <Value>6379</Value>
      <Name>REDIS_PORT</Name>
      <Mode/>
    </Var>
    <Var>
      <Value>192.168.1.6</Value>
      <Name>MYSQL_HOST</Name>
      <Mode/>
    </Var>
    <Var>
      <Value>3306</Value>
      <Name>MYSQL_PORT</Name>
      <Mode/>
    </Var>
    <Var>
      <Value>root</Value>
      <Name>MYSQL_USER</Name>
      <Mode/>
    </Var>
    <Var>
      <Value></Value>
      <Name>MYSQL_PASSWORD</Name>
      <Mode/>
    </Var>
    <Var>
      <Value>gpuhub</Value>
      <Name>MYSQL_DATABASE</Name>
      <Mode/>
    </Var>
  </Environment>
  <Labels/>
  <Config Name="Host Port 1" Target="8001" Default="8001" Mode="tcp" Description="Container Port: 8001" Type="Port" Display="always" Required="true" Mask="false">8001</Config>
  <Config Name="Redis Host" Target="REDIS_HOST" Default="192.168.1.6" Mode="" Description="Redis server host" Type="Variable" Display="always" Required="true" Mask="false">192.168.1.6</Config>
  <Config Name="Redis Port" Target="REDIS_PORT" Default="6379" Mode="" Description="Redis server port" Type="Variable" Display="always" Required="true" Mask="false">6379</Config>
  <Config Name="MySQL Host" Target="MYSQL_HOST" Default="192.168.1.6" Mode="" Description="MySQL server host" Type="Variable" Display="always" Required="true" Mask="false">192.168.1.6</Config>
  <Config Name="MySQL Port" Target="MYSQL_PORT" Default="3306" Mode="" Description="MySQL server port" Type="Variable" Display="always" Required="true" Mask="false">3306</Config>
  <Config Name="MySQL User" Target="MYSQL_USER" Default="root" Mode="" Description="MySQL user" Type="Variable" Display="always" Required="true" Mask="false">root</Config>
  <Config Name="MySQL Password" Target="MYSQL_PASSWORD" Default="" Mode="" Description="MySQL password" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="MySQL Database" Target="MYSQL_DATABASE" Default="gpuhub" Mode="" Description="MySQL database name" Type="Variable" Display="always" Required="true" Mask="false">gpuhub</Config>
</Container>