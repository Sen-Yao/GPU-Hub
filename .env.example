# GPUHub 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# GPUHub 服务端口（避免冲突时修改）
GPUHUB_PORT=8003

# Redis 配置
REDIS_HOST=your.redis.host
REDIS_PORT=6379
REDIS_PASSWORD=              # 如果Redis无密码，留空

# MySQL 配置
MYSQL_HOST=your.mysql.host
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password    # ⚠️ 必须填写
MYSQL_DATABASE=gpuhub

# Node Agent 配置（算力端）
CONTROL_PLANE_URL=https://your-domain.com
NODE_ID=worker-node-01
HEARTBEAT_INTERVAL=10
FETCH_INTERVAL=5